    },
    {
      "page": "/app/live-log",
      "regex": "^/app/live\\-log(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/app/live\\-log(?:/)?$"
    },
    {
      "page": "/app/settings",
      "regex": "^/app/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/app/settings(?:/)?$"
    },
    {
      "page": "/app/tenants",
      "regex": "^/app/tenants(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/app/tenants(?:/)?$"
    },
    {
      "page": "/benchmarks",
      "regex": "^/benchmarks(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/benchmarks(?:/)?$"
    },
    {
      "page": "/changelog",
      "regex": "^/changelog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/changelog(?:/)?$"
    },
    {
      "page": "/docs",
      "regex": "^/docs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/docs(?:/)?$"
    },
    {
      "page": "/faq",
      "regex": "^/faq(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faq(?:/)?$"
    },
    {
      "page": "/integrations",
      "regex": "^/integrations(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/integrations(?:/)?$"
    },
    {
      "page": "/product",
      "regex": "^/product(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/product(?:/)?$"
    },
    {
      "page": "/roadmap",
      "regex": "^/roadmap(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/roadmap(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/security",
      "regex": "^/security(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/security(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
